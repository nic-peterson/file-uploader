<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard - File Uploader</title>
  <link rel="stylesheet" href="/style.css" />
</head>
<body>
  <div class="page-wrap">

    <div class="topbar">
      <h1>Welcome, <%= user.name || user.email %>!</h1>
      <div class="topbar-actions">
        <span class="view-toggle">
          <% if (viewMode === 'folder') { %>
            <span class="active">Folders</span> &nbsp;|&nbsp; <a href="?view=flat">Flat</a>
          <% } else { %>
            <a href="/dashboard">Folders</a> &nbsp;|&nbsp; <span class="active">Flat</span>
          <% } %>
        </span>
        <form action="/logout" method="POST" style="margin:0;">
          <button type="submit" class="btn--logout">Log out</button>
        </form>
      </div>
    </div>

    <% if (messages && messages.error && messages.error.length > 0) { %>
      <div class="flash flash--error"><%= messages.error[0] %></div>
    <% } %>
    <% if (messages && messages.success && messages.success.length > 0) { %>
      <div class="flash flash--success"><%= messages.success[0] %></div>
    <% } %>

    <% if (viewMode === 'folder') { %>

      <!-- Folders section -->
      <div class="card">
        <h2>Folders</h2>
        <form action="/folders" method="POST" class="form-row" style="margin-bottom: 1rem;">
          <input type="text" name="name" placeholder="New folder name" required />
          <button type="submit" class="btn btn--primary btn--sm">Create Folder</button>
        </form>

        <% if (folders && folders.length > 0) { %>
          <table>
            <thead>
              <tr>
                <th>Name</th>
                <th>Files</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% folders.forEach(function(folder) { %>
                <tr>
                  <td><a href="/folders/<%= folder.id %>"><%= folder.name %></a></td>
                  <td style="color: var(--muted);"><%= folder._count.files %></td>
                  <td>
                    <div class="td-actions">
                      <form action="/folders/<%= folder.id %>/rename" method="POST" class="rename-form">
                        <input type="text" name="name" value="<%= folder.name %>" required />
                        <button type="submit" class="btn btn--ghost btn--sm">Rename</button>
                      </form>
                      <form action="/folders/<%= folder.id %>/delete" method="POST">
                        <button type="submit" class="btn btn--danger btn--sm">Delete</button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        <% } else { %>
          <p class="empty-state">No folders yet.</p>
        <% } %>
      </div>

      <!-- Upload section -->
      <div class="card">
        <h2>Upload a File</h2>
        <form action="/files/upload" method="POST" enctype="multipart/form-data" class="form-row">
          <input type="file" name="file" required />
          <select name="folderId">
            <option value="">No folder</option>
            <% if (folders) { folders.forEach(function(folder) { %>
              <option value="<%= folder.id %>"><%= folder.name %></option>
            <% }); } %>
          </select>
          <button type="submit" class="btn btn--primary btn--sm">Upload</button>
        </form>
      </div>

      <!-- Uncategorized files -->
      <div class="card">
        <h2>Uncategorized Files</h2>
        <% if (rootFiles && rootFiles.length > 0) { %>
          <table>
            <thead>
              <tr>
                <th>Name</th>
                <th>Type</th>
                <th>Size</th>
                <th>Uploaded</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% rootFiles.forEach(function(file) { %>
                <tr>
                  <td><%= file.name %></td>
                  <td style="color: var(--muted);"><%= file.type %></td>
                  <td style="color: var(--muted);"><%= (file.size / 1024).toFixed(1) %> KB</td>
                  <td style="color: var(--muted);"><%= new Date(file.createdAt).toLocaleDateString() %></td>
                  <td>
                    <div class="td-actions">
                      <a href="/files/<%= file.id %>/download" class="btn btn--ghost btn--sm">Download</a>
                      <form action="/files/<%= file.id %>/move" method="POST" class="form-row" style="gap:0.3rem;">
                        <select name="folderId" style="font-size:0.78rem; padding: 0.25rem 0.4rem;">
                          <option value="">Root</option>
                          <% if (folders) { folders.forEach(function(folder) { %>
                            <option value="<%= folder.id %>"><%= folder.name %></option>
                          <% }); } %>
                        </select>
                        <button type="submit" class="btn btn--ghost btn--sm">Move</button>
                      </form>
                      <form action="/files/<%= file.id %>/delete" method="POST">
                        <button type="submit" class="btn btn--danger btn--sm">Delete</button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        <% } else { %>
          <p class="empty-state">No uncategorized files.</p>
        <% } %>
      </div>

    <% } else { %>

      <!-- Flat view -->
      <div class="card">
        <h2>Upload a File</h2>
        <form action="/files/upload" method="POST" enctype="multipart/form-data" class="form-row">
          <input type="file" name="file" required />
          <select name="folderId">
            <option value="">No folder</option>
            <% if (folders) { folders.forEach(function(folder) { %>
              <option value="<%= folder.id %>"><%= folder.name %></option>
            <% }); } %>
          </select>
          <button type="submit" class="btn btn--primary btn--sm">Upload</button>
        </form>
      </div>

      <div class="card">
        <h2>All Files</h2>
        <div class="flat-tree">
<% if (folders) { folders.forEach(function(folder) { %>
<span class="folder-heading">📁 <%= folder.name %> (<%= folder._count.files %> files)</span>
<% const folderFiles = files ? files.filter(function(f) { return f.folderId === folder.id; }) : []; %>
<% folderFiles.forEach(function(file) { %><span class="file-line">• <%= file.name %>  <%= (file.size / 1024).toFixed(1) %> KB  <%= new Date(file.createdAt).toLocaleDateString() %></span>
<% }); %>
<% if (folderFiles.length === 0) { %><span class="empty">  (empty)</span>
<% } %>

<% }); } %>
<span class="folder-heading">📁 Root</span>
<% const rootFilesList = files ? files.filter(function(f) { return !f.folderId; }) : []; %>
<% rootFilesList.forEach(function(file) { %><span class="file-line">• <%= file.name %>  <%= (file.size / 1024).toFixed(1) %> KB  <%= new Date(file.createdAt).toLocaleDateString() %></span>
<% }); %>
<% if (rootFilesList.length === 0) { %><span class="empty">  (empty)</span>
<% } %>
        </div>

        <% if (files && files.length > 0) { %>
          <table style="margin-top: 1.5rem;">
            <thead>
              <tr>
                <th>Name</th>
                <th>Type</th>
                <th>Size</th>
                <th>Uploaded</th>
                <th>Folder</th>
                <th>Actions</th>
              </tr>
            </thead>
            <tbody>
              <% files.forEach(function(file) { %>
                <tr>
                  <td><%= file.name %></td>
                  <td style="color: var(--muted);"><%= file.type %></td>
                  <td style="color: var(--muted);"><%= (file.size / 1024).toFixed(1) %> KB</td>
                  <td style="color: var(--muted);"><%= new Date(file.createdAt).toLocaleDateString() %></td>
                  <td style="color: var(--muted);">
                    <% const fileFolder = folders ? folders.find(function(fd) { return fd.id === file.folderId; }) : null; %>
                    <%= fileFolder ? fileFolder.name : 'Root' %>
                  </td>
                  <td>
                    <div class="td-actions">
                      <a href="/files/<%= file.id %>/download" class="btn btn--ghost btn--sm">Download</a>
                      <form action="/files/<%= file.id %>/move" method="POST" class="form-row" style="gap:0.3rem;">
                        <select name="folderId" style="font-size:0.78rem; padding: 0.25rem 0.4rem;">
                          <option value="">Root</option>
                          <% if (folders) { folders.forEach(function(folder) { %>
                            <option value="<%= folder.id %>" <%= file.folderId === folder.id ? 'selected' : '' %>><%= folder.name %></option>
                          <% }); } %>
                        </select>
                        <button type="submit" class="btn btn--ghost btn--sm">Move</button>
                      </form>
                      <form action="/files/<%= file.id %>/delete" method="POST">
                        <button type="submit" class="btn btn--danger btn--sm">Delete</button>
                      </form>
                    </div>
                  </td>
                </tr>
              <% }); %>
            </tbody>
          </table>
        <% } else { %>
          <p class="empty-state">No files uploaded yet.</p>
        <% } %>
      </div>

    <% } %>

  </div>
</body>
</html>
