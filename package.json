{
  "dependencies": {
    "@prisma/client": "^6.3.1",
    "@supabase/supabase-js": "^2.98.0",
    "bcrypt": "^5.1.1",
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^16.4.7",
    "ejs": "^4.0.1",
    "express": "^4.21.2",
    "express-flash": "^0.0.2",
    "express-session": "^1.18.1",
    "multer": "^1.4.5-lts.1",
    "passport": "^0.7.0",
    "passport-local": "^1.0.0",
    "prisma": "^6.3.1"
  },
  "devDependencies": {
    "dotenv-cli": "^8.0.0",
    "eslint": "^9.20.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.3",
    "jest": "^29.7.0",
    "prettier": "^3.5.0",
    "supertest": "^7.0.0"
  },
  "jest": {
    "setupFiles": [
      "./jest.setup.js"
    ]
  },
  "scripts": {
    "start": "NODE_ENV=production npx prisma migrate deploy && node src/server.js",
    "dev": "NODE_ENV=development dotenv -e .env.development node src/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "server": "node --watch src/server.js",
    "clean": "rm -rf node_modules package-lock.json",
    "reinstall": "npm run clean && npm install",
    "postinstall": "prisma generate",
    "prisma:dev": "dotenv -e .env.development prisma",
    "migrate:dev": "dotenv -e .env.development prisma migrate dev",
    "studio:dev": "dotenv -e .env.development prisma studio"
  }
}
